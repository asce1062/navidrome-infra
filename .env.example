# Copy values into Coolify environment variables or a local .env file.
# Do not commit .env files.

# Image pin. `latest` is convenient, but production can pin a known-good tag.
NAVIDROME_IMAGE=deluan/navidrome:latest

# Host path containing the music catalog. The container mounts this read-only.
NAVIDROME_MUSIC_DIR=/opt/navidrome/music

# Navidrome runtime settings.
ND_SCANSCHEDULE=1h
ND_LOGLEVEL=info
ND_SESSIONTIMEOUT=24h
ND_ENABLETRANSCODINGCONFIG=true

# Optional. Leave empty when Navidrome is served at the domain root.
ND_BASEURL=

# Optional text shown on the login page.
ND_UIWELCOMEMESSAGE=
